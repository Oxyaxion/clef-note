#!/usr/bin/env bash
# cn — Clef Note CLI
# Commands: ls, get, put, rm, mv, query, search, shares, key
# Config:   CN_URL (default: http://localhost:3000)
#           CN_KEY or CLEF_NOTE_KEY
#           CN_PARTITION or -p/--partition <slug> — target a specific
#           partition's notes (ls, get, put, rm, mv) instead of the server's
#           active one; unset uses whichever partition is active.

set -euo pipefail

CN_URL="${CN_URL:-${AN_URL:-${CLEF_NOTE_URL:-http://localhost:3000}}}"
CN_KEY="${CN_KEY:-${AN_KEY:-${CLEF_NOTE_KEY:-}}}"
CN_PARTITION="${CN_PARTITION:-}"

# Optional leading -p/--partition <slug> flag, e.g. `cn -p notes rm foo`
if [[ "${1:-}" == "--partition" || "${1:-}" == "-p" ]]; then
    CN_PARTITION="${2:-}"
    shift 2
fi

auth_args=()
[[ -n "$CN_KEY" ]] && auth_args+=(-H "Authorization: Bearer $CN_KEY")
[[ -n "$CN_PARTITION" ]] && auth_args+=(-H "X-Partition: $CN_PARTITION")

BOLD=$'\e[1m'
DIM=$'\e[2m'
RED=$'\e[31m'
RESET=$'\e[0m'

urlencode() {
    printf '%s' "$1" | jq -Rr 'split("/") | map(@uri) | join("/")'
}

# Run curl and print a readable error on failure instead of bare exit code 22.
cn_curl() {
    local out http_code body
    out=$(curl -s -w "%{http_code}" "$@")
    http_code="${out: -3}"
    body="${out:0:${#out}-3}"
    if [[ "$http_code" -ge 400 ]]; then
        local msg
        msg=$(printf '%s' "$body" | jq -r '.error // empty' 2>/dev/null || true)
        [[ -z "$msg" ]] && msg="HTTP $http_code"
        printf '%sError: %s%s\n' "$RED" "$msg" "$RESET" >&2
        return 1
    fi
    printf '%s' "$body"
}

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in

  ls|list)
    result=$(cn_curl "${auth_args[@]}" "$CN_URL/notes")
    echo "$result" | jq -r '.[] | (if .pinned then "★" else " " end) + " " + .name'
    echo ""
    echo "$result" | jq -r '(length|tostring) + " notes"'
    ;;

  get|cat|read)
    [[ -z "${1:-}" ]] && { echo "Usage: cn get <name>"; exit 1; }
    name="$(urlencode "$1")"
    cn_curl "${auth_args[@]}" "$CN_URL/notes/$name" | jq -r '.content // ""'
    ;;

  put|write|save)
    [[ -z "${1:-}" ]] && { echo "Usage: cn put <name> < file.md"; exit 1; }
    name="$(urlencode "$1")"
    content="$(cat)"
    payload=$(jq -Rn --arg c "$content" '{"content": $c}')
    cn_curl -X PUT "${auth_args[@]}" \
      -H "Content-Type: application/json" \
      -d "$payload" \
      "$CN_URL/notes/$name" > /dev/null
    echo "Saved: $1"
    ;;

  rm|delete|del)
    [[ -z "${1:-}" ]] && { echo "Usage: cn rm <name>"; exit 1; }
    name="$(urlencode "$1")"
    cn_curl -X DELETE "${auth_args[@]}" "$CN_URL/notes/$name" > /dev/null
    echo "Deleted: $1"
    ;;

  mv|rename)
    [[ -z "${1:-}" || -z "${2:-}" ]] && { echo "Usage: cn mv <old-name> <new-name>"; exit 1; }
    old="$(urlencode "$1")"
    payload=$(jq -Rn --arg n "$2" '{"new_name": $n}')
    cn_curl -X PATCH "${auth_args[@]}" \
      -H "Content-Type: application/json" \
      -d "$payload" \
      "$CN_URL/notes/$old" > /dev/null
    echo "Renamed: $1 → $2"
    ;;

  query|q)
    [[ -z "${1:-}" ]] && { echo "Usage: cn query '<DSL>'"; exit 1; }
    q="$(printf '%s' "$1" | jq -Rr @uri)"
    result=$(cn_curl "${auth_args[@]}" "$CN_URL/api/query?q=$q")
    echo "$result" | jq -r --arg dim "$DIM" --arg reset "$RESET" '
      .[] |
      (.title // .name) as $title |
      ( [ (.tags // [] | join(", ")),
          (.status // ""),
          (.date   // ""),
          (.area   // "") ]
        | map(select(. != ""))
        | join(" · ") ) as $meta |
      $title,
      if $meta != "" then "  " + $dim + $meta + $reset else empty end
    '
    count=$(echo "$result" | jq -r 'length')
    [[ "$count" -gt 0 ]] && echo ""
    printf '%s%s result(s)%s\n' "$DIM" "$count" "$RESET"
    ;;

  search|s)
    [[ -z "${1:-}" ]] && { echo "Usage: cn search '<text>'"; exit 1; }
    q="$(printf '%s' "$1" | jq -Rr @uri)"
    result=$(cn_curl "${auth_args[@]}" "$CN_URL/api/search?q=$q")
    echo "$result" | jq -r --arg bold "$BOLD" --arg dim "$DIM" --arg reset "$RESET" '
      .[] |
      $bold + (.title // .name) + $reset,
      "  " + (.snippet // ""),
      ""
    '
    printf '%s%s result(s)%s\n' "$DIM" "$(echo "$result" | jq -r 'length')" "$RESET"
    ;;

  shares|share)
    subcmd="${1:-ls}"
    shift 2>/dev/null || true
    case "$subcmd" in
      ls|list)
        result=$(cn_curl "${auth_args[@]}" "$CN_URL/api/shares")
        echo "$result" | jq -r --arg dim "$DIM" --arg reset "$RESET" '
          .[] |
          (.slug) as $slug |
          (.note) as $note |
          (if .has_password then " 🔒" else "" end) as $pw |
          (if .expires_at then " (expires " + (.expires_at | split("T")[0]) + ")" else "" end) as $exp |
          $note + $pw + $exp + $dim + "  /shared/" + $slug + $reset
        '
        count=$(echo "$result" | jq -r 'length')
        [[ "$count" -gt 0 ]] && echo ""
        echo "$count share(s)"
        ;;
      rm|delete|del)
        [[ -z "${1:-}" ]] && { echo "Usage: cn shares rm <slug>"; exit 1; }
        cn_curl -X DELETE "${auth_args[@]}" "$CN_URL/api/shares/$1" > /dev/null
        echo "Deleted share: $1"
        ;;
      *)
        echo "Usage: cn shares [ls|rm <slug>]" >&2
        exit 1
        ;;
    esac
    ;;

  key)
    cn_curl "${auth_args[@]}" "$CN_URL/api/key" \
      | jq -r '"API key: " + (.api_key // "(not set)")'
    ;;

  help|--help|-h|'')
    cat <<'EOF'
cn — Clef Note CLI

Usage: cn [-p|--partition <slug>] <command> [args]

Commands:
  ls                      List all notes (★ = pinned)
  get  <name>             Print note content
  put  <name>             Create/overwrite note from stdin
  rm   <name>             Delete a note
  mv   <old> <new>        Rename a note
  query '<q>'             DSL query  (#tag, status:x, area:y, recent:10 …)
  search '<text>'         Full-text search
  shares                  List all shared links
  shares rm <slug>        Delete a shared link
  key                     Show API key

Config (env vars):
  CN_URL         Backend URL   (default: http://localhost:3000)
  CN_KEY         API key       (fallback: CLEF_NOTE_KEY)
  CN_PARTITION   Partition slug to target for ls/get/put/rm/mv (fallback:
                 -p/--partition flag; unset uses the server's active
                 partition — see `cn` vs the web UI's partition switcher)

Examples:
  cn ls
  cn get "Dev/Rust - lifetimes"
  cn -p notes rm "Test MCP - Note de vérification"
  echo "# Hello" | cn put "scratch"
  cn mv "scratch" "Notes/scratch"
  cn query "#rust status:active"
  cn search "ownership"
  cn shares
  cn shares rm my-note-abc123
EOF
    ;;

  *)
    echo "Unknown command: $cmd  (try: cn help)" >&2
    exit 1
    ;;
esac
