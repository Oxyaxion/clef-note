# Clef Note — configuration
# Copy to clef-note.toml and fill in your values.

# Required — web UI password (Argon2 hash).
# Generate with: ./clef-note --hash-password "yourpassword"
password = "$argon2id$v=19$..."

# Optional — storage directory.
# Default: ../storage relative to the binary.
# Can also be overridden at runtime with: ./clef-note --storage /mnt/notes
# storage = "/mnt/notes"

# Optional — listening port. Default: 3000.
# Can also be overridden at runtime with: ./clef-note --port 8080
# port = 3000

# Optional — API key for programmatic access (CLI scripts/an, REST, OpenAPI).
# Generate with: openssl rand -hex 32
# api_key = ""

# Optional — git sync. Synchronise storage/ with a remote repository.
# Supports GitHub, Gitea, Forgejo, GitLab (HTTPS + personal access token).
#
# GitHub token: Settings → Developer settings → Personal access tokens
#               → Fine-grained → Contents: Read and write
# Gitea/Forgejo: User Settings → Applications → Generate token
#
# [sync]
# remote           = "https://github.com/you/notes.git"
# branch           = "main"
# token            = "ghp_xxxx"
# interval_minutes = 30        # 0 = manual only (Settings → Git Sync → Sync now)
# author_name      = "clef-note"    # optional — git commit author name
# author_email     = "sync@local"   # optional — git commit author email
